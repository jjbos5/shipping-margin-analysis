 # ──────────────────────────────────────────
  # SECRETS — never commit these
  # ──────────────────────────────────────────
  .env
  .env.*
  !.env.example
  *.pem
  *.key
  secrets.*
  credentials.*
  *.token

  # ──────────────────────────────────────────
  # DATA — real customer data stays out
  # ──────────────────────────────────────────
  data/
  *.csv
  *.db
  *.sqlite
  *.sqlite3
  *.parquet

  # ──────────────────────────────────────────
  # PYTHON
  # ──────────────────────────────────────────
  __pycache__/
  *.pyc
  *.pyo
  *.pyd
  .venv/
  venv/
  env/
  .pytest_cache/
  .mypy_cache/
  .coverage
  *.egg-info/

  # ──────────────────────────────────────────
  # EDITORS / IDE
  # ──────────────────────────────────────────
  .vscode/
  .idea/
  *.swp
  *.swo

  # ──────────────────────────────────────────
  # OS JUNK
  # ──────────────────────────────────────────
  .DS_Store
  Thumbs.db
  desktop.ini

  # ──────────────────────────────────────────
  # LOGS
  # ──────────────────────────────────────────
  *.log
  logs/